{
  "expo": {
    "name": "Attendly",
    "slug": "my-expo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rooshan.attendly"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rooshan.attendly"
    },
    "owner": "shani_03",
    "splash": {
      "image": "./assets/AppIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1f36"
    },
    "extra": {
      "eas": {
        "projectId": "e5524f68-7b0a-4c89-a1f6-86b17b4bc745"
      }
    },
    "plugins": [
      "expo-font",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/AppIcon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1f36"
        }
      ],
      [
        "expo-status-bar",
        {
          "style": "light",
          "backgroundColor": "#1a1f36",
          "translucent": false
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}